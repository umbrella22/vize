{
  "name": "rspack-vize-plugin-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rspack dev",
    "build": "rspack build",
    "preview": "rspack preview",
    "check": "vp check src rspack.config.ts vite.config.ts",
