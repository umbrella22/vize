    "fmt": "vp fmt --write src rspack.config.ts vite.config.ts"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.7",
    "@rspack/core": "^1.7.7",
    "@vizejs/rspack-plugin": "workspace:*",
    "typescript": "^5.8.3",
    "vize": "workspace:*"
  }
}
