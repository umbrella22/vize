{
  "name": "@vizejs/rspack-plugin",
  "version": "0.33.0",
  "description": "High-performance Rspack plugin for Vue SFC compilation powered by Vize",
  "keywords": [
    "compiler",
    "fast",
    "loader",
    "native",
    "plugin",
    "rspack",
    "sfc",
    "vue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize",
    "directory": "npm/rspack-vize-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "default": "./dist/loader/index.js"
    },
    "./style-loader": {
      "types": "./dist/loader/style-loader.d.ts",
      "import": "./dist/loader/style-loader.js",
      "default": "./dist/loader/style-loader.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts",
    "test": "pnpm build && node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "test:update": "pnpm build && node --import tsx --test --test-update-snapshots src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@vizejs/native": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "^1.7.7",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.6.0",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  }
}
